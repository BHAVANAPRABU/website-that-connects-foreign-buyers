from flask import Flask, render_template_string, request, redirect

app = Flask(__name__)

buyers = []
sellers = []

HTML = """
<!DOCTYPE html>
<html>
<head>
    <title>Global Trade Connect</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial;
        }

        body{
            background:#f4f7fb;
        }

        header{
            background:#0b5ed7;
            color:white;
            padding:20px;
            text-align:center;
        }

        .hero{
            background:url('https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?q=80&w=1200&auto=format&fit=crop') center/cover;
            height:300px;
            display:flex;
            align-items:center;
            justify-content:center;
            color:white;
            font-size:40px;
            font-weight:bold;
            text-shadow:2px 2px 5px black;
        }

        .container{
            width:90%;
            margin:auto;
            padding:20px;
        }

        .cards{
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:20px;
            margin-top:20px;
        }

        .card{
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0px 0px 10px rgba(0,0,0,0.1);
        }

        input, textarea{
            width:100%;
            padding:10px;
            margin-top:10px;
            border:1px solid #ccc;
            border-radius:5px;
        }

        button{
            margin-top:15px;
            width:100%;
            padding:12px;
            border:none;
            background:#0b5ed7;
            color:white;
            font-size:16px;
            border-radius:5px;
            cursor:pointer;
        }

        button:hover{
            background:#084298;
        }

        h2{
            margin-bottom:10px;
            color:#0b5ed7;
        }

        .list-section{
            margin-top:40px;
        }

        .item{
            background:white;
            padding:15px;
            margin-top:10px;
            border-radius:8px;
            box-shadow:0px 0px 5px rgba(0,0,0,0.1);
        }

        footer{
            margin-top:40px;
            background:#0b5ed7;
            color:white;
            text-align:center;
            padding:15px;
        }

        @media(max-width:768px){
            .cards{
                grid-template-columns:1fr;
            }

            .hero{
                font-size:28px;
                text-align:center;
                padding:20px;
            }
        }
    </style>
</head>

<body>

<header>
    <h1>Global Trade Connect</h1>
    <p>Connecting Foreign Buyers with Indian Sellers</p>
</header>

<div class="hero">
    International B2B Marketplace
</div>

<div class="container">

    <div class="cards">

        <!-- SELLER FORM -->
        <div class="card">
            <h2>Seller Registration</h2>

            <form method="POST" action="/add_seller">

                <input type="text" name="name" placeholder="Company Name" required>

                <input type="text" name="product" placeholder="Product Name" required>

                <input type="text" name="country" placeholder="Country" required>

                <textarea name="details" placeholder="Product Details"></textarea>

                <button type="submit">Register Seller</button>

            </form>
        </div>

        <!-- BUYER FORM -->
        <div class="card">
            <h2>Buyer Registration</h2>

            <form method="POST" action="/add_buyer">

                <input type="text" name="name" placeholder="Buyer Name" required>

                <input type="text" name="need" placeholder="Required Product" required>

                <input type="text" name="country" placeholder="Country" required>

                <textarea name="details" placeholder="Requirement Details"></textarea>

                <button type="submit">Register Buyer</button>

            </form>
        </div>

    </div>

    <!-- SELLERS LIST -->
    <div class="list-section">
        <h2>Registered Sellers</h2>

        {% for s in sellers %}
        <div class="item">
            <h3>{{s.name}}</h3>
            <p><b>Product:</b> {{s.product}}</p>
            <p><b>Country:</b> {{s.country}}</p>
            <p>{{s.details}}</p>
        </div>
        {% endfor %}
    </div>

    <!-- BUYERS LIST -->
    <div class="list-section">
        <h2>Registered Buyers</h2>

        {% for b in buyers %}
        <div class="item">
            <h3>{{b.name}}</h3>
            <p><b>Need:</b> {{b.need}}</p>
            <p><b>Country:</b> {{b.country}}</p>
            <p>{{b.details}}</p>
        </div>
        {% endfor %}
    </div>

</div>

<footer>
    © 2026 Global Trade Connect | Made with Python Flask
</footer>

</body>
</html>
"""

@app.route('/')
def home():
    return render_template_string(HTML, buyers=buyers, sellers=sellers)

@app.route('/add_seller', methods=['POST'])
def add_seller():
    seller = {
        "name": request.form['name'],
        "product": request.form['product'],
        "country": request.form['country'],
        "details": request.form['details']
    }

    sellers.append(seller)

    return redirect('/')

@app.route('/add_buyer', methods=['POST'])
def add_buyer():
    buyer = {
        "name": request.form['name'],
        "need": request.form['need'],
        "country": request.form['country'],
        "details": request.form['details']
    }

    buyers.append(buyer)

    return redirect('/')

if __name__ == '__main__':
    app.run(debug=True)
```
